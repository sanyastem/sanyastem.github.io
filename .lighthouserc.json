{
  "ci": {
    "collect": {
      "staticDistDir": "./_site",
      "url": [
        "http://localhost/index.html",
        "http://localhost/web/responsive-design/index.html",
        "http://localhost/devops/docker-basics/index.html",
        "http://localhost/tools/claude-code-mcp/index.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":     ["warn",  { "minScore": 0.85 }],
        "categories:accessibility":   ["error", { "minScore": 0.9 }],
        "categories:best-practices":  ["warn",  { "minScore": 0.9 }],
        "categories:seo":             ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
